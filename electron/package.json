{
  "name": "sentinel",
  "version": "0.1.0",
  "description": "Temporal Threat Intelligence Engine",
  "main": "main.js",
  "author": "Sarthak Naikare <sarthaknaikare@gmail.com>",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.sarthaknaikare.sentinel",
    "productName": "SENTINEL",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^26.0.12"
  }
}
